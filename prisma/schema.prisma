// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model LegacyWatchlist {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  userId  String   @db.ObjectId
  movieId String   @db.ObjectId
  addedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id])
  movie   Movie    @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId])
  @@map("Watchlist")
}

model Liked {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  userId  String   @db.ObjectId
  movieId String   @db.ObjectId
  addedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id])
  movie   Movie    @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId])
  @@index([userId, addedAt])
  @@index([movieId])
}

// Add this new model to your schema.prisma file
model EntityReaction {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  entityId     String   @db.ObjectId
  entityType   String // "review", "blog", etc.
  reactionType String // "likes", "fire", etc.
  createdAt    DateTime @default(now())

  // Relation to user
  user User @relation(fields: [userId], references: [id])

  @@unique([userId, entityId, entityType, reactionType])
  @@index([entityId, entityType])
  @@index([userId])
}

model Rating {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  value     Float
  userId    String   @db.ObjectId
  movieId   String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  movie Movie @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId]) // Ensures a unique combination of userId and movieId
  @@index([userId])
  @@index([movieId])
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  userId    String   @db.ObjectId
  movieId   String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user           User            @relation(fields: [userId], references: [id])
  movie          Movie           @relation(fields: [movieId], references: [id])
  reviewComments reviewComment[]

  // Engagement Metrics
  likes      Int @default(0)
  fire       Int @default(0)
  popularity Int @default(0)

  @@unique([userId, movieId]) // Ensures a unique combination of userId and movieId
  @@index([userId, createdAt])
  @@index([movieId, createdAt])
  @@index([createdAt])
}

model Blog {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  title      String
  content    String
  hashtags   String?
  blogNumber Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  tags       String[] // Tags like ['Review', 'Art', 'Drama']
  thumbnail  String? // Optional cover image for the blog
  likes      Int           @default(0)
  fire       Int           @default(0)
  views      Int           @default(0)
  comments   BlogComment[] // Relationship to comments

  // Relations
  userEmail String
  user      User   @relation(fields: [userEmail], references: [email])

  @@index([userEmail, createdAt])
  @@index([createdAt])
}
model reviewComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  comment   String
  userId    String   @db.ObjectId
  reviewId  String   @db.ObjectId
  parentId  String?  @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  review Review @relation(fields: [reviewId], references: [id])

  // Self-referencing relation (Fix: Add `onDelete` and `onUpdate`)
  parentComment reviewComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childComments reviewComment[] @relation("CommentReplies")

  @@index([reviewId])
  @@index([parentId])
}

model Movie {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  tmdbId    String      @unique
  title     String
  posterUrl String?
  watchlist LegacyWatchlist[]
  watchlistItems WatchlistItem[]
  liked     Liked[]
  ratings   Rating[]
  reviews   Review[] // Relationship to reviews

  // cached leaderboard counter (non-null with 0 default for easy sorting)
  votes Int @default(0)

  // relation
  movieVotes MovieVote[]

  // optional: speed up sorts
  @@index([votes])
}

model User {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  username        String?          @unique
  email           String           @unique
  password        String?
  bio             String?
  image           String?
  avatarUrl       String?
  emailVerified   DateTime?
  movieGenres     String[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  watchlist       LegacyWatchlist[]
  liked           Liked[]
  ratings         Rating[]
  reviews         Review[]
  reviewComment   reviewComment[]
  blogs           Blog[]
  blogComments    BlogComment[]
  entityReactions EntityReaction[]

  followedBy Follow[] @relation("followers")
  following  Follow[] @relation("following")

  movieVotes MovieVote[]

  videos Video[]

  videoComments VideoComment[]

  watchlistCollections Watchlist[] @relation("WatchlistOwner")
  watchlistMemberships WatchlistMember[] @relation("WatchlistMemberships")
  watchlistMemberInvitesSent WatchlistMember[] @relation("WatchlistMemberInvitedBy")
  watchlistItemsAdded  WatchlistItem[] @relation("WatchlistItemsAdded")
  watchlistInvitesSent WatchlistInvite[] @relation("WatchlistInvitesSent")
  watchlistInviteTargets WatchlistInvite[] @relation("WatchlistInviteTargetUser")
  watchlistActivities WatchlistActivity[] @relation("WatchlistActivityActor")
  notifications       Notification[] @relation("notifications")
  sentNotifications   Notification[] @relation("sentNotifications")
}

model Watchlist {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerId    String   @map("userId") @db.ObjectId
  name       String
  slug       String
  visibility WatchlistVisibility?
  isPublic   Boolean  @default(false) // legacy mirror field for backward compatibility
  coverImage String?
  isSystemDefault Boolean?
  shareToken String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner      User               @relation("WatchlistOwner", fields: [ownerId], references: [id])
  items      WatchlistItem[]
  members    WatchlistMember[]
  invites    WatchlistInvite[]
  activities WatchlistActivity[]

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@index([ownerId, updatedAt])
  @@index([visibility])
  @@map("WatchlistCollection")
}

model WatchlistItem {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  watchlistId  String   @map("collectionId") @db.ObjectId
  movieId      String   @db.ObjectId
  addedByUserId String? @db.ObjectId
  notes        String?
  rank         Float?
  addedAt      DateTime @default(now())
  updatedAt    DateTime? @updatedAt

  watchlist   Watchlist          @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  movie       Movie              @relation(fields: [movieId], references: [id], onDelete: Cascade)
  addedByUser User?              @relation("WatchlistItemsAdded", fields: [addedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([watchlistId, movieId])
  @@index([watchlistId])
  @@index([watchlistId, rank])
  @@index([movieId])
  @@map("WatchlistCollectionItem")
}

model WatchlistMember {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  watchlistId    String               @db.ObjectId
  userId         String               @db.ObjectId
  role           WatchlistMemberRole
  status         WatchlistMemberStatus @default(ACTIVE)
  invitedByUserId String?             @db.ObjectId
  joinedAt       DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  watchlist      Watchlist            @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  user           User                 @relation("WatchlistMemberships", fields: [userId], references: [id], onDelete: Cascade)
  invitedByUser  User?                @relation("WatchlistMemberInvitedBy", fields: [invitedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([watchlistId, userId])
  @@index([userId, status])
}

model WatchlistInvite {
  id              String              @id @default(auto()) @map("_id") @db.ObjectId
  watchlistId     String              @db.ObjectId
  token           String              @unique
  email           String?
  invitedUserId   String?             @db.ObjectId
  invitedByUserId String              @db.ObjectId
  role            WatchlistMemberRole
  status          WatchlistInviteStatus @default(INVITED)
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  watchlist       Watchlist           @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  invitedUser     User?               @relation("WatchlistInviteTargetUser", fields: [invitedUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invitedByUser   User                @relation("WatchlistInvitesSent", fields: [invitedByUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([watchlistId, status])
  @@index([expiresAt])
}

model WatchlistActivity {
  id         String               @id @default(auto()) @map("_id") @db.ObjectId
  watchlistId String              @db.ObjectId
  actorId    String?              @db.ObjectId
  type       WatchlistActivityType
  movieId    String?              @db.ObjectId
  targetUserId String?            @db.ObjectId
  metadata   Json?
  createdAt  DateTime             @default(now())

  watchlist  Watchlist            @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  actor      User?                @relation("WatchlistActivityActor", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([watchlistId, createdAt])
}

model Notification {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  userId     String           @db.ObjectId
  actorId    String?          @db.ObjectId
  type       NotificationType
  entityType String?
  entityId   String?
  title      String
  body       String?
  link       String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user  User  @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("sentNotifications", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model MovieVote {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  movieId   String   @db.ObjectId
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  movie Movie @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId]) // 1 vote per user per movie
  @@index([movieId])
  @@index([userId])
}

model Follow {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  follower    User     @relation("following", fields: [followerId], references: [id])
  followerId  String   @db.ObjectId
  following   User     @relation("followers", fields: [followingId], references: [id])
  followingId String   @db.ObjectId
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model AuthToken {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  tokenHash  String        @unique
  type       AuthTokenType
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([identifier, type])
  @@index([expiresAt])
}

model Account {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.String
  access_token      String?  @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.String
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}



model BlogComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  userId    String   @db.ObjectId
  blogId    String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parentId      String?       @db.ObjectId
  parentComment BlogComment?  @relation("BlogCommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  childComments BlogComment[] @relation("BlogCommentReplies")

  // **New Fields**
  // likes       Int           @default(0)  // Likes on comments
  taggedUsers String[] @db.ObjectId
  // Stores @mentions (e.g., ["john_doe", "jane_smith"])

  // Relations
  user User @relation(fields: [userId], references: [id])
  blog Blog @relation(fields: [blogId], references: [id])

  @@index([blogId]) // Adding an index for quicker lookups by blogId
  @@index([parentId])
}

model Video {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  title         String
  description   String?
  language      String?
  posterUrl     String?
  tags          String[]
  genres        String[]
  cast          String[]

  writer        String?
  director      String?

  visibility    String   @default("public") // or use enum Visibility if you want

  ageRestricted Boolean  @default(false)

  // Mux integration
  muxAssetId    String? 
  muxPlaybackId String? 
  status        String   @default("pending") // or VideoStatus enum

  // Cached counters
  views         Int      @default(0)
  likes         Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
  comments      VideoComment[]

  @@index([userId])
  @@index([status])
  @@index([visibility])
  // optional, if you plan to query by them:
  @@index([muxAssetId])
  @@index([muxPlaybackId])
}


enum Visibility {
  public
  unlisted
  private
}

enum WatchlistVisibility {
  PRIVATE
  SHARED
}

enum WatchlistMemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum WatchlistMemberStatus {
  ACTIVE
  INVITED
  REVOKED
  LEFT
}

enum WatchlistInviteStatus {
  INVITED
  ACCEPTED
  REVOKED
  EXPIRED
}

enum WatchlistActivityType {
  WATCHLIST_CREATED
  WATCHLIST_UPDATED
  ITEM_ADDED
  ITEM_REMOVED
  ITEMS_REORDERED
  MEMBER_INVITED
  MEMBER_JOINED
}

enum VideoStatus {
  pending
  processing
  ready
  failed
}

enum AuthTokenType {
  email_verification
  password_reset
}

enum NotificationType {
  FOLLOW
  REACTION_LIKE
  REACTION_FIRE
  SYSTEM
}


model VideoComment {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  videoId    String   @db.ObjectId
  content    String
  parentId   String?  @db.ObjectId
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User  @relation(fields: [userId], references: [id])
  video   Video @relation(fields: [videoId], references: [id])

  // Fixed: Added onDelete and onUpdate actions
  parent   VideoComment?   @relation("VideoCommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children VideoComment[]  @relation("VideoCommentReplies")

  @@index([videoId])
  @@index([parentId])
}

// Tracks a Mux direct-upload until the asset is processed
model UploadTicket {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  videoId      String   @db.ObjectId
  muxUploadId  String   @unique
  status       String   @default("uploading") // uploading | asset_created | ready | errored
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
