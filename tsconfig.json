{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["dom", "dom.iterable", "esnext" , "ES2018"],
    "downlevelIteration": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/app/libs/prismaDB.jsx", "src/app/api/[...nextauth]/route.jsx", "src/app/layout.tsx", "src/app/(pages)/liked/page.jsx", "src/app/api/auth/[...nextauth]/options.js", "src/app/api/auth/[...nextauth]/connect.js", "src/app/api/blog/[slug]/route.jsx", "src/app/(pages)/profile/page.jsx", "src/app/components/Hero/Hero.jsx", "src/app/api/watchlist/status/route.jsx", "src/app/api/trending_movies_week/route.jsx", "src/app/api/feed/route.jsx", "src/app/api/reaction/video/route.jsx", "src/app/api/review/route.ts"],
  "exclude": ["node_modules"]
}
